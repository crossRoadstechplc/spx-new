# Phase 1: Environment variables template
# Copy this file to .env.local and fill in your values

# ============================================
# Application Core
# ============================================
NODE_ENV="development"
APP_URL="http://localhost:3000"

# ============================================
# Database (Phase 1)
# ============================================
DATABASE_URL="file:./dev.db"

# ============================================
# Authentication (Phase 3)
# ============================================
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Admin credentials (Phase 3)
ADMIN_EMAIL="admin@spx.com"
ADMIN_PASSWORD_HASH="your-bcrypt-hash-here"

# ============================================
# Email / SMTP (Phase 7)
# ============================================
SMTP_HOST="gvam1219.siteground.biz"
SMTP_PORT="465"
SMTP_USER="contact@spxafrica.com"
SMTP_PASS="dttadtn123"
SMTP_FROM="SPX <contact@spxafrica.com>"
CONTACT_RECIPIENT_EMAIL="contact@spxafrica.com"
CAREERS_RECIPIENT_EMAIL="contact@spxafrica.com"

# ============================================
# File Uploads (Phase 1)
# ============================================
# Relative to project root
UPLOAD_DIR="./public/uploads"
# Maximum file size in bytes (10MB default)
MAX_UPLOAD_SIZE="10485760"
# Allowed image MIME types (comma-separated)
ALLOWED_IMAGE_TYPES="image/jpeg,image/png,image/webp,image/gif"
